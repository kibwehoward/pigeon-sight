# ============================================
# PostgreSQL Configuration
# ============================================
POSTGRES_USER=your_db_username
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name

# ============================================
# pgAdmin Configuration
# ============================================
PGADMIN_DEFAULT_EMAIL=your_email@example.com
PGADMIN_DEFAULT_PASSWORD=your_password

# ============================================
# Network Configuration
# ============================================
NETWORK_NAME=your_external_network

# ============================================
# Database connection details
# ============================================
db_credentials = {
    "host": "your_db_hostname",         # Replace with the database host (e.g., IP or hostname)
    "port": "your_db_port",             # Replace with the PostgreSQL/PostGIS port (e.g., 5432)
    "database": "your_db_name",         # Replace with the name of your database
    "username": "your_db_username",     # Replace with your PostgreSQL/PostGIS username
    "password": "your_db_password"      # Replace with your PostgreSQL/PostGIS password
}